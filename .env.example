# ========== Data Agent 环境变量配置模板 ==========
# 复制此文件为 .env 并填入真实值
# 优先级高于 backend/conf/app_config.yaml 中的值

# LLM 配置
DATA_AGENT_LLM_API_KEY=sk-your-api-key
DATA_AGENT_LLM_BASE_URL=https://api.deepseek.com
DATA_AGENT_LLM_MODEL_NAME=deepseek-v4-flash

# Embedding 服务
DATA_AGENT_EMBEDDING_API_KEY=hf_your_huggingface_token

# 元数据库
DATA_AGENT_DB_META_PASSWORD=your_meta_db_password

# 数仓数据库
DATA_AGENT_DB_DW_PASSWORD=your_dw_db_password
